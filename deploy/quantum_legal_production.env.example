# Sprint S6 — Quantum Legal API 프로덕션 환경 변수 예시
# cp deploy/quantum_legal_production.env.example deploy/quantum_legal_production.env

# --- HTTP 서버 ---
PORT=8080
SEED_PATH=assets/data/legal_hierarchy_seed.json

# --- 경찰 IAM JWT ---
# none | claims | strict
NPA_IAM_JWT_MODE=claims
NPA_IAM_ISSUER=https://iam.police.go.kr
NPA_IAM_AUDIENCE=sgp-agent-api
NPA_IAM_JWKS_URL=https://iam.police.go.kr/.well-known/jwks.json
NPA_IAM_VERIFY_JWKS=true

# --- 법령 Cron (sync_law_nodes_production.dart) ---
LAW_GO_KR_OC_KEY=
DATA_GO_KR_SERVICE_KEY=
OUTPUT_PATH=build/legal_nodes_sync.json
SQL_OUTPUT_PATH=build/legal_triples_upsert.sql
# true 시 LAW_GO_KR_OC_KEY 미설정이면 Cron 실패(exit 2) — 운영 배치용
LAW_SYNC_REQUIRE_LIVE_KEY=false
LAW_API_MAX_RETRIES=3
LAW_API_RETRY_DELAY_MS=1500

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=sgp_legal
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=sgp_legal
DATABASE_URL=postgresql://sgp_legal:change_me_in_production@localhost:5432/sgp_legal
